import io
import numpy as np
import tensorflow as tf
from fastapi import FastAPI, File, UploadFile, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from PIL import Image

app = FastAPI(
    title="Sea Animals Classification API",
    description="API untuk mengklasifikasi 23 jenis hewan laut berbasis EfficientNetB3"
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

CLASS_NAMES = [
    'Clams', 'Corals', 'Crabs', 'Dolphin', 'Eel', 
    'Fish', 'Jelly Fish', 'Lobster', 'Nudibranchs', 'Octopus', 
    'Otter', 'Penguin', 'Puffers', 'Sea Rays', 'Sea Urchins', 
    'Seahorse', 'Seal', 'Sharks', 'Shrimp', 'Squid', 
    'Starfish', 'Turtle_Tortoise', 'Whale'
]

IMG_SIZE = (300, 300)
MODEL_PATH = "model/sea_animals_efficientnetb3.keras"

try:
    model = tf.keras.models.load_model(MODEL_PATH, compile=False)
    print("Model sukses dimuat.")
except Exception as e:
    print(f"Gagal memuat model. Error: {e}")
    model = None

def preprocess_image(image_bytes: bytes):
    image = Image.open(io.BytesIO(image_bytes)).convert("RGB")
    image = image.resize(IMG_SIZE)
    image_array = np.array(image, dtype=np.float32)
    image_array = np.expand_dims(image_array, axis=0)
    return image_array

@app.post("/predict")
async def predict(file: UploadFile = File(...)):
    if model is None:
        raise HTTPException(status_code=500, detail="Model ML belum siap atau tidak ditemukan di server.")
    
    if file.content_type not in ["image/jpeg", "image/png", "image/jpg"]:
        raise HTTPException(status_code=400, detail="Format file harus berupa gambar (JPEG/PNG).")
    
    try:
        image_bytes = await file.read()
        input_data = preprocess_image(image_bytes)
        
        predictions = model.predict(input_data, verbose=0)
        confidence = float(np.max(predictions[0]) * 100)
        
        if confidence < 60:
            predicted_class = "Unknown"
        else:
            predicted_class = CLASS_NAMES[np.argmax(predictions[0])]
        
        return {
            "success": True,
            "prediction": predicted_class,
            "confidence": round(confidence, 2)
        }
        
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Terjadi kesalahan saat memproses gambar: {str(e)}")

@app.get("/")
def read_root():
    return {"status": "Server berjalan", "model_loaded": model is not None}